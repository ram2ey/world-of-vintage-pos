# ─── Database ────────────────────────────────────────────────────────────────
# Azure PostgreSQL Flexible Server
DATABASE_URL="postgresql://wov_admin:CHANGE_ME@wov-db.postgres.database.azure.com:5432/world_of_vintage?sslmode=require"

# ─── Auth ─────────────────────────────────────────────────────────────────────
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET="change-me-to-a-long-random-string"
JWT_REFRESH_SECRET="change-me-refresh-secret"
JWT_EXPIRES_IN="15m"
JWT_REFRESH_EXPIRES_IN="7d"

# ─── Server ───────────────────────────────────────────────────────────────────
PORT=3000
NODE_ENV=development

# ─── Client ───────────────────────────────────────────────────────────────────
# Production: set to your Azure Static Web Apps URL
# e.g. https://wov-frontend.azurestaticapps.net
CLIENT_URL="http://localhost:5173"

# ─── Frontend (set in Azure Static Web Apps → Configuration) ─────────────────
# VITE_API_URL=https://wov-api.azurewebsites.net
