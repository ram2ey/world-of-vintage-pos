generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Catalogue ────────────────────────────────────────────────────────────────

model Category {
  id       String    @id @default(cuid())
  name     String
  icon     String    // lucide-react icon name
  colorHex String    @map("color_hex")
  products Product[]

  @@map("categories")
}

model Product {
  id          String     @id @default(cuid())
  name        String
  categoryId  String     @map("category_id")
  category    Category   @relation(fields: [categoryId], references: [id])
  description String?
  imageUrl    String?    @map("image_url")
  basePrice   Decimal    @map("base_price") @db.Decimal(10, 2)
  barcode     String?    @unique
  isActive    Boolean    @default(true) @map("is_active")
  createdAt   DateTime   @default(now()) @map("created_at")
  variants    Variant[]
  markdowns   Markdown[]

  @@map("products")
}

model Variant {
  id                String            @id @default(cuid())
  productId         String            @map("product_id")
  product           Product           @relation(fields: [productId], references: [id], onDelete: Cascade)
  size              String
  color             String
  colorHex          String            @map("color_hex")
  quantity          Int               @default(0)
  sku               String            @unique
  lowStockThreshold Int               @default(3) @map("low_stock_threshold")
  transactionItems  TransactionItem[]

  @@map("variants")
}

// ─── Customers ────────────────────────────────────────────────────────────────

model Customer {
  id             String          @id @default(cuid())
  name           String
  phone          String          @unique
  email          String?
  preferredSizes Json            @default("[]") @map("preferred_sizes")
  styleNotes     String?         @map("style_notes")
  createdAt      DateTime        @default(now()) @map("created_at")
  visits         CustomerVisit[]
  transactions   Transaction[]

  @@map("customers")
}

model CustomerVisit {
  id            String       @id @default(cuid())
  customerId    String       @map("customer_id")
  customer      Customer     @relation(fields: [customerId], references: [id])
  visitedAt     DateTime     @default(now()) @map("visited_at")
  transactionId String?      @unique @map("transaction_id")
  transaction   Transaction? @relation(fields: [transactionId], references: [id])

  @@map("customer_visits")
}

// ─── Transactions ─────────────────────────────────────────────────────────────

model Transaction {
  id             String            @id @default(cuid())
  customerId     String?           @map("customer_id")
  customer       Customer?         @relation(fields: [customerId], references: [id])
  staffId        String            @map("staff_id")
  staff          Staff             @relation(fields: [staffId], references: [id])
  subtotal       Decimal           @db.Decimal(10, 2)
  discountAmount Decimal           @default(0) @map("discount_amount") @db.Decimal(10, 2)
  total          Decimal           @db.Decimal(10, 2)
  status         TransactionStatus @default(completed)
  paymentMethod  String            @map("payment_method")
  paymentSplit   Json?             @map("payment_split")
  receiptNumber  String            @unique @map("receipt_number")
  createdAt      DateTime          @default(now()) @map("created_at")
  items          TransactionItem[]
  customerVisit  CustomerVisit?

  @@map("transactions")
}

enum TransactionStatus {
  completed
  voided
  pending_sync
}

model TransactionItem {
  id            String      @id @default(cuid())
  transactionId String      @map("transaction_id")
  transaction   Transaction @relation(fields: [transactionId], references: [id], onDelete: Cascade)
  variantId     String      @map("variant_id")
  variant       Variant     @relation(fields: [variantId], references: [id])
  quantity      Int
  unitPrice     Decimal     @map("unit_price") @db.Decimal(10, 2)
  lineTotal     Decimal     @map("line_total") @db.Decimal(10, 2)

  @@map("transaction_items")
}

// ─── Promotions ───────────────────────────────────────────────────────────────

model Discount {
  id        String       @id @default(cuid())
  code      String       @unique
  type      DiscountType
  value     Decimal      @db.Decimal(10, 2)
  expiresAt DateTime?    @map("expires_at")
  isActive  Boolean      @default(true) @map("is_active")

  @@map("discounts")
}

enum DiscountType {
  percentage
  fixed
}

model Markdown {
  id                 String   @id @default(cuid())
  productId          String   @map("product_id")
  product            Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  discountPercentage Decimal  @map("discount_percentage") @db.Decimal(5, 2)
  startsAt           DateTime @map("starts_at")
  endsAt             DateTime @map("ends_at")
  isActive           Boolean  @default(true) @map("is_active")

  @@map("markdowns")
}

// ─── Staff ────────────────────────────────────────────────────────────────────

model Staff {
  id           String        @id @default(cuid())
  name         String
  pin          String        // bcrypt-hashed
  role         StaffRole
  isActive     Boolean       @default(true) @map("is_active")
  transactions Transaction[]

  @@map("staff")
}

enum StaffRole {
  cashier
  manager
}
